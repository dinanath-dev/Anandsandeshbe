PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

SUPABASE_URL=https://bpmvlrtfvuhkuarwcyox.supabase.co
# Dashboard → API Keys → service_role (secret). Not anon / not publishable.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET=payment-screenshots

# Form + payment rows table (create with sql/create_anand_sandesh_subscription.sql). Legacy: SUBMISSIONS_TABLE=submissions
SUBMISSIONS_TABLE=anand_sandesh_subscription

JWT_SECRET=replace-with-a-long-random-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-admin-password

AUTH_OTP_TTL_MINUTES=10
AUTH_JWT_EXPIRES_IN=7d
AUTH_OTP_SECRET=replace-with-a-separate-random-secret
AUTH_OTP_TABLE=auth_otps
AUTH_USER_TABLE=auth_users

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
MAIL_FROM="Anand Sandesh <no-reply@example.com>"
# Optional: Publication Society's PAN to print on payment-success bill emails. Leave blank to render as a blank line.
MAIL_BILL_PAN=

# Razorpay recurring subscriptions
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Optional: public https URL to the same image as frontend/src/assets/bg.avif (cover + overlay match the app).
# Example after deploy: https://yoursite.com/assets/bg-XXXX.avif — many clients load external backgrounds when images are allowed.
MAIL_BG_IMAGE_URL=

# Optional: absolute path to bg.avif for OTP + payment receipt emails (inline CID). If unset, tries backend/bg.avif then backend/assets/bg.avif.
# MAIL_BG_AVIF_PATH=/absolute/path/to/bg.avif

# Optional: copy each form save to Google Sheets (same data as public.submissions)
# 1) Google Cloud → enable Sheets API → create service account → download JSON key
# 2) Share the spreadsheet with the service account email (Editor)
# 3) Set spreadsheet ID from the sheet URL, and either:
#    GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/sa.json
#    OR one-line JSON in GOOGLE_SERVICE_ACCOUNT_JSON (escape newlines in private_key)
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_RANGE=Sheet1!A:Z
# GOOGLE_APPLICATION_CREDENTIALS=
# GOOGLE_SERVICE_ACCOUNT_JSON=
